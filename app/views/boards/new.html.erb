<div class="container">
  <div class="row">
    <div class="col-lg-8 offset-lg-2">
      <h1>掲示板作成</h1>
      <%= form_with model: @board, local: true, class: "needs-validation" do |f|  %>
          <%= f.label :title %> 
          <%= f.text_field :title %>
          <%= f.label :body %>
          <%= f.text_field :body %>
          <%= f.submit "Submit" %>
      <% end %> 
    </div>
  </div>
</div>