<% content_for(:title, t('.title')) %>
<div class="container pt-3">
  <div class="row">
    <div class="col-lg-10 offset-lg-1">
      <!-- 検索フォーム -->
      <%= render 'search_form', url: boards_path %>
    </div>
  </div>
  <!-- 掲示板一覧 -->
  <div class="row">
    <div class="col-12">
      <div class="row">
        <% if @boards.present? %>
          <%# @boards.each do |board| %>
            <%#= render partial: 'board', locals: { board: board } %>
          <%= render @boards %> 
            <%# end %>
        <% else %>
          <%= t('.no_result') %>
        <% end %>
      </div>
    </div>
  </div>
  <div class="d-flex justify-content-center">
    <%= paginate @boards, theme: 'twitter-bootstrap-4' %>
  </div>
</div>