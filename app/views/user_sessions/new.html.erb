<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-10 col-lg-8">
      <h1 class="text-center mb-4">ログイン</h1>

      <%= form_with url: login_path, local: true, class: "needs-validation" do |f| %>
        <div class="mb-3">
          <%= f.label :email, "メールアドレス", class: "form-label" %>
          <%= f.email_field :email, class: "form-control", required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :password, "パスワード", class: "form-label" %>
          <%= f.password_field :password, class: "form-control", required: true %>
        </div>
        <div class="d-grid mb-3">
          <%= f.submit "ログイン", class: "btn btn-primary btn-sm px-4" %>
        </div>
      <% end %>

      <div class="text-center mt-3">
        <%= link_to '登録ページへ', new_user_path, class: "d-block mb-2" %>
        <%= link_to 'パスワードをお忘れの方はこちら', "#", class: "d-block text-muted" %>
      </div>
    </div>
  </div>
</div>
