<% content_for(:title, t('.title')) %>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-10 col-lg-8">
      <h1 class="text-center mb-4"><%= t('.title') %></h1>

      <%= form_with url: login_path, local: true, class: "needs-validation" do |f| %>
        <div class="mb-3">
          <%= f.label :email, User.human_attribute_name(:email), class: "form-label" %>
          <%= f.email_field :email, class: "form-control", required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :password, User.human_attribute_name(:password), class: "form-label" %>
          <%= f.password_field :password, class: "form-control", required: true %>
        </div>
        <div class="d-grid mb-3">
          <%= f.submit t('defaults.login'), class: "btn btn-primary btn-sm px-4" %>
        </div>
      <% end %>

      <div class="text-center mt-3">
        <%= link_to t('.to_register_page'), new_user_path, class: "d-block mb-2" %>
        <%= link_to t('.password_forget'), "#", class: "d-block text-muted" %>
      </div>
    </div>
  </div>
</div>
