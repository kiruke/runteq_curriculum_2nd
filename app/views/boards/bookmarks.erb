<% content_for(:title, t('.title')) %>
<div class="container pt-3">
  <div class="row">
    <div class="col-lg-10 offset-lg-1">
      <!-- 検索フォーム -->
      <%= render 'search_form' %>
    </div>
  </div>
  <!-- ブックマーク一覧 -->
  <div class="row">
    <div class="col-12">
      <div class="row">
        <% if @board_bookmarks.present? %>
          <% @board_bookmarks.each do |bookmark| %>
            <%= render partial: 'boards/board', locals: { board: bookmark } %>
          <% end %>
        <% else %>
          <%= t('.no_result') %>
        <% end %>
      </div>
    </div>
  </div>
</div>